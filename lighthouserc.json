{
  "ci": {
    "collect": {
      "startServerCommand": "python3 -m http.server 8080 --directory builds/web",
      "url": ["http://localhost:8080/index.html"],
      "numberOfRuns": 1,
      "settings": {
        "onlyCategories": ["performance", "pwa"],
        "preset": "desktop"
      }
    },
    "assert": {
      "assertions": {
        "categories:pwa": ["error", {"minScore": 0.8}]
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
